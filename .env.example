# LLM API configuration (supports any LLM API compatible with the OpenAI SDK format)
# Recommended: z.ai GLM-4.7 via the OpenAI-compatible API
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.z.ai/api/coding/paas/v4
LLM_MODEL_NAME=glm-4.7

# ===== ZEP memory graph configuration =====
# The free monthly quota is enough for basic usage: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Accelerated LLM configuration (optional) =====
# If you do not use the accelerated configuration, omit the following variables from the env file
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here
