# Flask 配置
SECRET_KEY=your_secret_key_here
FLASK_DEBUG=True

# LLM API配置（支持 OpenAI SDK 格式的任意 LLM API）
# 推荐使用阿里百炼平台qwen-plus模型：https://bailian.console.aliyun.com/
# 注意消耗较大，可先进行小于40轮的模拟尝试
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus
LLM_MAX_RETRIES=3
NEO4J_MAX_RETRIES=3
NEO4J_RETRY_DELAY=1
ZEP_MAX_RETRIES=3

# ===== 图数据库存储选择 =====
# 可选值: "zep" (云服务) 或 "neo4j" (本地自建)
GRAPH_STORAGE=zep

# ===== ZEP记忆图谱配置 (当 GRAPH_STORAGE=zep 时需要配置) =====
# 每月免费额度即可支撑简单使用：https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Neo4j 本地图数据库配置 (当 GRAPH_STORAGE=neo4j 时需要配置) =====
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j

# ===== pgvector 向量数据库配置（可选，当使用本地向量存储时配置）=====
# PostgreSQL + pgvector 作为向量存储，替代Zep内置向量库，适合私有化部署
# PGVECTOR_HOST=localhost
# PGVECTOR_PORT=5432
# PGVECTOR_DATABASE=mirofish
# PGVECTOR_USER=postgres
# PGVECTOR_PASSWORD=your_pg_password_here
# PGVECTOR_EMBEDDING_DIMENSION=1536
# PGVECTOR_TABLE=embeddings

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== OASIS 模拟配置（可选）=====
# 默认最大模拟轮数，可根据需求调整
# OASIS_DEFAULT_MAX_ROUNDS=10